# Copy this file to deploy.config (gitignored) and set your path.
# deploy.config is never committed — it stays local only.
#
# Windows example:
#   ST_EXTENSIONS_DIR=E:\SillyTavern\public\scripts\extensions\third-party
#
# Linux / macOS example:
#   ST_EXTENSIONS_DIR=/home/user/SillyTavern/public/scripts/extensions/third-party

ST_EXTENSIONS_DIR=
