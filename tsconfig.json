{
    "compilerOptions": {
        "checkJs": true,
        "allowJs": true,
        "noEmit": true,
        "strict": false,
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "lib": ["ES2020", "DOM"],
        "skipLibCheck": true
    },
    "include": ["src/**/*.js", "index.js"],
    "exclude": ["node_modules", "lib"]
}
